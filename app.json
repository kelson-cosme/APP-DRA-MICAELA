{
  "expo": {
    "name": "Dra Micaela Vargas",
    "slug": "Dra Micaela Vargas",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logoApp.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logoApp.png",
      "resizeMode": "contain",
      "backgroundColor": "#312A27"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dramicaelavargas.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoApp.png",
        "backgroundColor": "#312A27"
      },
      "package": "com.dramicaelavargas.app",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/logoApp.png"
    },
    "extra": {
      "eas": {
        "projectId": "9f242d56-7837-4d43-963f-bf0cca9366c5"
      }
    },
    "notification": {
      "icon": "./assets/logoApp.png",
      "color": "#D4AF37"
    },
    "plugins": [
      "expo-video"
    ]
  }
}