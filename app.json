{
  "expo": {
    "name": "Dra Micaela Vargas",
    "slug": "dra-micaela-vargas",
    "version": "1.0.0",
    "scheme": "dramicaelavargas",
    "orientation": "portrait",
    "icon": "./assets/logoApp.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logoApp.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.dramicaelavargas.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logoApp.png",
        "backgroundColor": "#312A27"
      },
      "package": "com.dramicaelavargas.app",
      "predictiveBackGestureEnabled": false,
      "googleServicesFile": "./google-services.json",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "dramicaelavargas"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "favicon": "./assets/logoApp.png"
    },
    "extra": {
      "eas": {
        "projectId": "9f242d56-7837-4d43-963f-bf0cca9366c5"
      }
    },
    "notification": {
      "icon": "./assets/notificacao.png",
      "color": "#D4AF37"
    },
    "plugins": [
      "expo-video",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "26.1.10909125"
          }
        }
      ]
    ]
  }
}